# API server port
PORT=3005

# ── LLM Provider ──────────────────────────────────────────────────────────────
# LLM_PROVIDER: "anthropic" (default) or "openai" (any OpenAI-compatible API)
LLM_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible provider (OpenRouter, Ollama, Together.ai, LM Studio, etc.)
# Set LLM_PROVIDER=openai and configure:
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_BASE_URL=http://localhost:11434/v1          # Ollama
# LLM_BASE_URL=http://localhost:1234/v1           # LM Studio
# LLM_API_KEY=sk-...                              # Provider API key

# Override model for all operations (optional)
# LLM_MODEL=gpt-4o
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct    # OpenRouter example
# LLM_MODEL=llama3.2                              # Ollama example
